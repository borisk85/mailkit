# ===== Supabase (required, Ticket #2) =====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Get from: https://supabase.com/dashboard/project/{id}/settings/api-keys

# ===== Google OAuth (Ticket #3) =====
# Supabase stores Client ID/Secret in its dashboard (Auth → Providers → Google).
# Values below are kept only as a reminder that OAuth is configured outside env.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Get from: console.cloud.google.com -> project mailkit-mvp ->
# APIs & Services -> Credentials -> OAuth client (Web app for production)

# ===== Cloudflare (Ticket #4 - setup pipeline) =====
# CLOUDFLARE_API_TOKEN=
# Get from: dash.cloudflare.com -> My Profile -> API Tokens
# Required scopes: Zone DNS Edit, Email Routing Rules Edit, Zone Settings Edit

# ===== Brevo (Ticket #4 - setup pipeline) =====
# BREVO_API_KEY=
# Get from: app.brevo.com -> SMTP & API -> API Keys

# ===== Lemon Squeezy (Ticket #7 - payments) =====
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_WEBHOOK_SECRET=
# Get from: app.lemonsqueezy.com -> Settings -> API
