# ===== Supabase (required, Ticket #2) =====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Get from: https://supabase.com/dashboard/project/{id}/settings/api-keys

# ===== Google OAuth (Ticket #3) =====
# Supabase stores Client ID/Secret in its dashboard (Auth → Providers → Google).
# Values below are kept only as a reminder that OAuth is configured outside env.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Get from: console.cloud.google.com -> project mailkit-mvp ->
# APIs & Services -> Credentials -> OAuth client (Web app for production)

# ===== Cloudflare (Ticket #4a - setup pipeline) =====
# User pastes their own API token per setup run; we never persist it.
# Base URL is constant, only override for staging/mocks.
CLOUDFLARE_API_BASE=https://api.cloudflare.com/client/v4
# Required user-token scopes (paste-token flow):
#   Zone:DNS:Edit, Zone:Zone:Edit, Zone:Zone Settings:Edit,
#   Account:Email Routing Addresses:Edit, Account:Email Routing Rules:Edit

# ===== AWS SES (feat/ses-backend-swap — replaces Brevo SMTP) =====
# Backend AWS account credentials for SES Tenant Management + IAM + CloudWatch.
# Region: us-east-1 (primary). See lib/integrations/ses.ts.
# Get from: AWS Console -> IAM -> Users -> mailkit-backend-prod -> Security credentials
# Policy required: mailkit-backend-policy (see feat/ses-backend-swap commit for JSON)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ACCOUNT_ID=  (12-digit number, find in AWS Console top-right menu)
AWS_SES_REGION=us-east-1

# ===== Brevo (Ticket #4 - setup pipeline) =====
# @deprecated 2026-04-30 — kept for fallback during SES migration,
# removed in #SES-6 post-launch (30 days after launch, no incidents).
# BREVO_API_KEY=
# Get from: app.brevo.com -> SMTP & API -> API Keys

# ===== Brevo transactional (Ticket #7 - auto-refund notification) =====
# @deprecated 2026-04-30 — transactional emails moving to SES in #SES-3.
# Sender identity for outbound transactional mail (auto-refund email,
# future welcome/receipt). Must be a verified sender in Brevo.
# Today: support@mailkit-test.ru (staging). At launch: rotate to
# support@getmailkit.com. Name is optional; defaults to "MailKit".
# MAILKIT_SUPPORT_FROM_EMAIL=support@mailkit-test.ru
# MAILKIT_SUPPORT_FROM_NAME=MailKit support

# ===== Brevo SMTP (Ticket #6 - Gmail Send-As wizard) =====
# @deprecated 2026-04-30 — replaced by per-tenant SES SMTP credentials
# (lib/integrations/ses.ts createSmtpCredentialsForTenant). These shared
# Brevo credentials are kept active during transition; removed in #SES-6.
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
# BREVO_SMTP_LOGIN= (auto-generated <accountID>@smtp-brevo.com, NOT account
#                    email; exact value in app.brevo.com → SMTP & API →
#                    SMTP tab → "Login" field — not from GET /v3/account)
# BREVO_SMTP_KEY= (64-char standard or 15-char short SMTP key)
# BREVO_SMTP_KEY_VERSION=1 (increment manually on rotation; see SECURITY.md)

# ===== Lemon Squeezy (Ticket #7 - payments) =====
# Test mode key initially; switch to live mode at launch. Test and
# live keys are separate — one does not authenticate the other.
# LEMONSQUEEZY_API_KEY=
# Get from: app.lemonsqueezy.com -> Settings -> API -> Create API key
#
# Signing secret for webhook request verification. Set when owner
# creates the webhook via LS Dashboard -> Settings -> Webhooks; LS
# shows the secret once at creation time, store it immediately.
# LEMONSQUEEZY_WEBHOOK_SECRET=
#
# Store ID (integer) — required for webhook creation endpoint and
# any store-scoped read. Find in LS Dashboard URL:
# /dashboard/stores/<id>. Can also fetch via `GET /v1/stores` with
# the API key — use data[0].id.
# LEMONSQUEEZY_STORE_ID=
#
# Checkout URL — full LS "buy" URL that /api/checkout/start redirects
# to for auth'd repeat-buyers from /app. Landing CTA embeds the same
# URL directly (unauth first-buy). Append promo/affiliate query
# params here if needed; our route preserves them and only sets the
# checkout[custom][user_id] + checkout[email] params.
# LEMONSQUEEZY_CHECKOUT_URL=https://velabot.lemonsqueezy.com/buy/<variant-uuid>

# ===== Anti-abuse cron (Tickets #21 + #22) =====
# Shared bearer secret for the Vercel Cron jobs that sync
# send_counters and deliverability_snapshots from Brevo. Vercel sets
# `Authorization: Bearer <CRON_SECRET>` automatically; the routes
# refuse other callers. Generate any 32+ byte random string.
# CRON_SECRET=

# ===== Sentry (Ticket #45 — error tracking) =====
# Public DSN — exposed to the client bundle. Safe; the DSN can only
# submit events to your Sentry project, not read or delete them.
# Get from: sentry.io → project settings → Client Keys (DSN).
# NEXT_PUBLIC_SENTRY_DSN=
# Server DSN — same value as the public one in most setups, but
# kept separate so a future migration to a server-only project ID
# doesn't require a code change.
# SENTRY_DSN=
# Auth token + org/project — required for source-map upload at build
# time. The token must NOT be committed; set on Vercel as a
# Production env var. Without it builds still succeed; the wrapper
# warns and skips upload.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ===== Site URL (used by sitemap.xml + robots.txt) =====
# Defaults to https://getmailkit.com if unset. Override on a preview
# deploy if you want sitemap entries pointing at the preview alias.
# NEXT_PUBLIC_SITE_URL=https://getmailkit.com
