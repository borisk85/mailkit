# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
tsconfig.tsbuildinfo

# spike artifacts (reference/spike/ has its own)
.venv/
__pycache__/
*.pyc
token.json
credentials.json
client_secret*.json
spike.log
*.log

# IDE
.idea/
.vscode/
/.claude/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/.playwright-mcp/

# Lighthouse reports (keep numbers in PR comments, not repo)
/lighthouse-*.json
/lighthouse-*.html

# UI verification screenshots (artifacts, attach to PR instead)
/shot-*.png
/i18n-*.png
/waitlist-*.png
/deploy-*.png
/wizard-*.png
/auth-*.png
/live-*.png
/preview-*.png

# Ad-hoc smoke scripts (not shipped, run manually). Build tools that
# do ship live in /tools/ instead.
/scripts/
!/scripts/abuse-export.ts

# Temporary public assets staged for Playwright tab-strip mocks etc.
/public/_temp/
